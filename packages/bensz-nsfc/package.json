{
  "name": "bensz-nsfc-common",
  "version": "p_v20260315",
  "description": "国家自然科学基金申请书 LaTeX 通用配置包（统一共性配置与项目差异）",
  "author": "ChineseResearchLaTeX Contributors",
  "license": "MIT",
  "repository": "https://github.com/huangwb8/ChineseResearchLaTeX",
  "installer": {
    "entry": "python packages/bensz-nsfc/scripts/install.py",
    "minimum_version": "p_v20260315",
    "default_ref": "main"
  },
  "templates": {
    "general": {
      "template_version": "t_v20260315"
    },
    "local": {
