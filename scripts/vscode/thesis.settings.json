{
  // Keep ALL LaTeX build artifacts in `.latex-cache/`.
  // The final deliverable stays in the project root as `main.pdf`.
  "latex-workshop.latex.outDir": ".latex-cache",
  "latex-workshop.latex.auxDir": ".latex-cache",

  // Prevent magic comments from bypassing the unified Python render pipeline.
  "latex-workshop.latex.build.enableMagicComments": false,
  "latex-workshop.latex.build.forceRecipeUsage": true,

  "latex-workshop.latex.recipe.default": "thesis build (python)",
  "latex-workshop.latex.recipes": [
    {
      "name": "thesis build (python)",
      "tools": [
        "thesis-python-build"
      ]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "thesis-python-build",
      "command": "bash",
      "args": [
        "-lc",
        "python3 scripts/thesis_build.py build --project-dir \"%DIR%\" --tex-file \"%DOCFILE%.tex\""
      ]
    }
  ],

  // Logging / UX
  "latex-workshop.message.log.level": "info",
  "latex-workshop.linting.chktex.enabled": false,
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.autoClean.run": "never",

  // PDF preview
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.synctex.afterBuild.enabled": true,

  // Explorer: hide cache dir and common root-level LaTeX intermediates.
  "files.exclude": {
    "%OUTDIR%/": true,
    "*.aux": true,
    "*.log": true,
    "*.out": true,
    "*.toc": true,
    "*.lof": true,
    "*.lot": true,
    "*.bbl": true,
    "*.blg": true,
    "*.bcf": true,
    "*.run.xml": true,
    "*.nav": true,
    "*.snm": true,
    "*.vrb": true,
    "*.fls": true,
    "*.fdb_latexmk": true,
    "*.synctex.gz": true,
    "*.synctex(busy)": true,
    "*.dvi": true,
    "*.xdv": true
  },
  "files.watcherExclude": {
    "**/.latex-cache/**": true
  }
}
